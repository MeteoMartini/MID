{
  "name": "open-meteo-weather-dashboard",
  "private": true,
  "version": "0.7.69",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "npm run sync-version",
    "build": "tsc -b && vite build",
    "verify": "npm run build && node --check worker/metar-proxy.js && npm run test:updater && npm run test:interactions && npm run test:radar && npm run test:precipitation && npm run test:sunshine && npm run test:hyperlocal",
    "preview": "vite preview",
    "test:updater": "node scripts/test-updater.mjs",
    "test:radar": "node scripts/test-radar.mjs",
    "test:interactions": "node scripts/test-interactions.mjs",
    "test:precipitation": "node scripts/test-precipitation.mjs",
    "test:sunshine": "node scripts/test-sunshine-format.mjs",
    "test:hyperlocal": "node scripts/test-hyperlocal-fields.mjs"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jsfive": "^0.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "@vitejs/plugin-react": "^4.4.1"
  },
  "overrides": {
    "@jridgewell/trace-mapping": "0.3.28"
  }
}
